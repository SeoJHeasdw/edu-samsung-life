# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.vinext/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
next-env.d.ts
/dist/
/.wrangler/
/outputs/
/work/

# typescript build info
*.tsbuildinfo

# project-specific — 강의 예제 / 개인 메모 / 빌드 산출물 (push 불필요)
/3D_design_example/
/claude_memory/
/benchmark/
/noname.png

# openai hosting config (개인 설정)
/.openai/

# 대용량 미디어 (git-lfs 미사용 시 제외)
public/assets/*.mp4
public/assets/*.mov
public/assets/*.avi
